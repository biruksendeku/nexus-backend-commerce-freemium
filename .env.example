
# Company Info - example value
YOUR_COMPANY_ADDRESS=1 Corporate Drive, Suite 200, Anytown, ST 12345
YOUR_COMPANY_NAME=Our Company

# System variables
NODE_ENV=development
PORT=8000

# App Config
BASE_URL=http://localhost:8000
STATIC_DIR=./public/

# Security
SESSION_SECRET_KEY=keyboard_cat
SALT=10

# Token Config
TOKEN_EXPIRATION_DAY=1
TOKEN_STRING_LENGTH=32

# Retry Logic
MAX_RETRIES=3
RETRY_DELAY=1000

# Product Config
MAX_IMAGE_LIMIT=5
MAX_IMAGE_SIZE=5
RECENT_DAY_AGE=7
POPULAR_PRODUCTS_SOLD=10
TOP_SELLING_PRODUCTS=3
TIMEOUT_MS=30_000

# Tax
TAX_PERCENT=15

# Database
MONGODB_URI=your_mongodb_connection_uri

# Stripe
STRIPE_SECRET_KEY=sk_test_placeholder_abc123
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER_NAME=my-cloudinary-folder

# Google Oauth credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback

# Facebook Oauth credentials
FACEBOOK_APP_ID=my-facebook-app-id
FACEBOOK_APP_SECRET=my-facebook-app-secret
